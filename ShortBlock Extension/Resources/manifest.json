{
    "manifest_version": 2,
    "name": "ShortBlock",
    "version": "1.0.0",
    "default_locale": "en",
    "description": "Blocks YouTube Shorts from appearing anywhere on YouTube",
    "icons": {
        "48": "images/icon-48.png",
        "96": "images/icon-96.png",
        "128": "images/icon-128.png",
        "256": "images/icon-256.png"
    },
    "permissions": [
        "storage"
    ],
    "content_scripts": [{
        "matches": [
            "*://www.youtube.com/*",
            "*://youtube.com/*",
            "*://m.youtube.com/*",
            "*://music.youtube.com/*"
        ],
        "js": ["content.js"],
        "run_at": "document_end"
    }],
    "browser_action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "images/toolbar-icon-16.png",
            "32": "images/toolbar-icon-32.png",
            "48": "images/toolbar-icon-48.png"
        }
    }
}
